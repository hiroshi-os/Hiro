{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hiro",
  "version": "0.1.0",
  "identifier": "com.bit.hiro",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",

    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"


  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hiro",
        "width": 460,
        "height": 680,
        "decorated": false,
        "transparent": true,
        "resizable": true,
        "minWidth": 380,
        "minHeight": 480
      }
    ],

    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
